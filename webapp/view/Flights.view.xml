<mvc:View controllerName="student.com.sap.training.advancedsapui5.fullscreen.controller.Flights"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" 
    xmlns:l="sap.ui.layout"
    xmlns:ux="sap.uxap"
    xmlns:cust="student.com.sap.training.advancedsapui5.fullscreen.control">
    <ux:ObjectPageLayout id="objectPageLayout">
        <ux:headerTitle>
            <ux:ObjectPageDynamicHeaderTitle id="objectPageDynamicHeader">
                <ux:expandedHeading>
                    <Title
                        id="fltitle"
                        text="{Carrname}"
                        level="H2"/>
                </ux:expandedHeading>
                <ux:navigationActions>
                    <OverflowToolbarButton
                        type="Transparent"
                        icon="sap-icon://decline"
                        press="handleClose"
                        tooltip="Close Middle Column"
                        visible="true"/>
                </ux:navigationActions>
            </ux:ObjectPageDynamicHeaderTitle>
        </ux:headerTitle>
        <ux:headerContent>
            <FlexBox
                id="flexbox"
                wrap="Wrap">
                <Avatar id="avatar" src="sap-icon://flight"/>
                <l:VerticalLayout
                    id="verticalLayout1"
                    class="sapUiSmallMarginBeginEnd">
                    <Label id="label1" text="{Carrid}"/>
                    <Label id="label2" text="{Url}"/>
                </l:VerticalLayout>
            </FlexBox>
        </ux:headerContent>
        <ux:sections>
            <ux:ObjectPageSection id="objectPageSection">
                <ux:ObjectPageSubSection id="objectPageSubSection1">
                    <Table 
                        id="idFlights" 
                        items="{path: 'to_Flight', sorter: {path: 'Carrid'}}"
                        mode="SingleSelectMaster"
                        growing="true"
                        growingThreshold="10">
                        
                    <headerToolbar>

                        <Toolbar id="toolbar1">
                            <Title id="title1" text="Flights" level="H2" />


                        </Toolbar>

                    </headerToolbar>
                    
                    <columns>
                        <Column id="flcarrnamecolumn" width="12em">
                            <Text id="flcarrnameheader" text="{i18n>carriername}" />
                        </Column>
                        <Column id="fldatecolumn" minScreenWidth="Tablet" demandPopin="true">
                            <Text id="fldateheader" text="{i18n>flightdate}" />
                        </Column>
                        <Column id="flseatmaxcolumn" minScreenWidth="Tablet" demandPopin="true">
                            <Text id="seatmaxheader" text="{i18n>seatmax}" />
                        </Column>
                        <Column id="flseatocccolumn" hAlign="Right">
                            <Text id="seatoccheader" text="{i18n>seatocc}" />
                        </Column>
                        <Column
                            id="flplaneinfo"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                            hAlign="Center">
                            <Text id="flplaneinfotext" text="{i18n>planeInfo}"/>
                        </Column>
                        <Column 
                            id="flbooking"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                            hAlign="Center">
                            <Text id="flbookingtext" text="{i18n>bookaction}"/>
                        </Column>
                    </columns>
                    
                    <items>
                        <ColumnListItem id="flcolumnListItem">
                            <cells>
                                <ObjectIdentifier id="flobjectIdentifier" title="{Carrid}" text="{Carrid}" />
                                <Text id="fldatetext" text="{path: 'Fldate', type: 'sap.ui.model.type.Date'}" />
                                <Text id="flseatsmaxtext" text="{Seatsmax}" />
                                <Text id="flseatsocctext" text="{Seatsocc}" />
                                <cust:PlaneInfo 
                                    id="planeInfo1"
                                    seatsMax="{Seatsmax}"
                                    seatsOcc="{Seatsocc}"/>
                                <cust:HoverButton
                                    id="hoverButton1"
                                    text="{i18n>bookaction}"
                                    allowHover="true"
                                    hoverText="{=${Seatsmax} - ${Seatsocc}}"
                                    hover="onHover"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>
                </ux:ObjectPageSubSection>
            </ux:ObjectPageSection>
        </ux:sections>
    </ux:ObjectPageLayout>
</mvc:View>
